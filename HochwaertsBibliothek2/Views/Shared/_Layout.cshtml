<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hochwärtsbibliothek</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HochwaertsBibliothek2.styles.css" asp-append-version="true" />
</head>

<body data-bs-theme="@(Context.Request.Cookies["theme"] == "theme-dark" ? "dark" : "light")">

    <header>
        <nav class="navbar navbar-expand-sm border-bottom box-shadow mb-3">
            <div class="container">

                <a class="navbar-brand d-flex align-items-center gap-2"
                   asp-controller="Start" asp-action="Index">
                    <img src="~/images/wappen.png" alt="Hochwärts Wappen" class="hw-wappen" />
                    <span class="fw-bold">Hochwärts-Bibliothek</span>
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Buecher" asp-action="Index">Bücher</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Exemplare" asp-action="Index">Exemplare</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Exemplare" asp-action="Ausleihe">Ausleihen</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Exemplare" asp-action="Ueberpruefung">Überprüfung</a>
                        </li>

                        <li class="nav-item ms-3">
                            <form method="post" asp-controller="Start" asp-action="SwitchTheme">
                                <button type="submit" class="btn btn-sm btn-outline-secondary">
                                    Theme wechseln
                                </button>
                            </form>
                        </li>

                    </ul>
                </div>

            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-4">

            @if (TempData["Fehler"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["Fehler"]
                </div>
            }

            @RenderBody()

        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container">
            &copy; 2026 - Hochwärts-Bibliothek
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>