@model HochwaertsBibliothek2.Models.Buch

@{
    ViewData["Title"] = "Buchdetails";
}

<div class="d-flex justify-content-between align-items-start">

    <div>
        <h1>@Model.Titel</h1>

        <p class="mb-1"><strong>Autor:</strong> @Model.Autor</p>
        <p class="mb-1"><strong>Jahr:</strong> @Model.Erscheinungsjahr</p>
        <p class="mb-1"><strong>ISBN:</strong> @Model.Isbn</p>

        @if (!string.IsNullOrWhiteSpace(Model.Klappentext))
        {
            <p class="mt-3">
                <strong>Klappentext:</strong><br />
                @Model.Klappentext
            </p>
        }

        @if (!string.IsNullOrWhiteSpace(Model.Inhalt))
        {
            <div class="mt-3">
                <details>
                    <summary>
                        <strong>Buchinhalt (Klick mich)</strong>
                    </summary>

                    <p class="mt-2">
                        @Model.Inhalt
                    </p>
                </details>
            </div>
        }
    </div>

    <div class="d-flex gap-2">
        <a class="btn btn-warning"
           asp-action="Bearbeiten"
           asp-route-id="@Model.BuchId">
            Bearbeiten
        </a>

        <a class="btn btn-secondary"
           asp-action="Index">
            Zur Liste
        </a>
    </div>

</div>

<hr />

<div class="d-flex justify-content-between align-items-center mb-2">
    <h3>Exemplare</h3>

    <a class="btn btn-success"
       asp-controller="Exemplare"
       asp-action="Registrieren"
       asp-route-buchId="@Model.BuchId">
        + Exemplar registrieren
    </a>
</div>

@if (Model.Exemplare == null || !Model.Exemplare.Any())
{
    <div class="alert alert-info">
        Noch keine Exemplare registriert.
    </div>
}
else
{
    <table class="table table-striped bg-white shadow-sm rounded-3 overflow-hidden">

        <thead class="table-light">
            <tr>
                <th>Exemplar</th>
                <th>Status</th>
                <th>Schaden</th>
                <th class="text-end">Aktion</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var exemplar in Model.Exemplare.OrderBy(e => e.ExemplarId))
            {
                <tr>
                    <td>#@exemplar.ExemplarId</td>
                    <td>@exemplar.Status</td>
                    <td>@exemplar.Beschädigung</td>

                    <td class="text-end">
                        <a class="btn btn-sm btn-secondary"
                           asp-controller="Exemplare"
                           asp-action="Details"
                           asp-route-id="@exemplar.ExemplarId">
                            Details
                        </a>
                    </td>
                </tr>
            }
        </tbody>

    </table>
}