@model IEnumerable<HochwaertsBibliothek2.Models.Exemplar>
@using HochwaertsBibliothek2.Models
@{
    ViewData["Title"] = "Überprüfung";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Überprüfung</h1>

<div class="p-4 rounded-4 shadow-sm bg-dark bg-opacity-10 mt-5">
    <div class="card shadow-sm border border-1 rounded-4">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Titel</th>
                            <th>Autor</th>
                            <th>Status</th>
                            <th>Beschädigung</th>
                            <th class="text-end">Aktionen</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var exemplar in Model)
                        {
                            <tr>
                                <td>@exemplar.Buch?.Titel</td>
                                <td>@exemplar.Buch?.Autor</td>
                                <td>Überprüfung</td>
                                <td>@exemplar.Beschädigung</td>

                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2 flex-wrap">
                                        <a class="btn btn-sm btn-secondary"
                                           asp-action="Details"
                                           asp-route-id="@exemplar.ExemplarId">
                                            Details
                                        </a>

                                        <a class="btn btn-sm btn-warning hw-action-btn"
                                           asp-action="Pruefen"
                                           asp-route-id="@exemplar.ExemplarId">
                                            Prüfen
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>
</div>